// RUN: ptoas --pto-arch=a3 %s 2>&1 | FileCheck %s --check-prefix=A3

module {
  func.func @cube_kernel(%gm_slot_buffer: memref<2048xf32, #pto.address_space<gm>>)
      attributes {pto.kernel_kind = #pto.kernel_kind<cube>} {
    %v2c_local = pto.reserve_buffer {
      name = "v2c_fifo",
      size = 8192,
      location = #pto.address_space<mat>,
      auto = true
    } -> i32
    %v2c_pipe = pto.initialize_l2g2l_pipe {
      dir_mask = 2,
      slot_size = 1024,
      slot_num = 8,
      local_slot_num = 8
    }(%gm_slot_buffer : memref<2048xf32, #pto.address_space<gm>>, %v2c_local : i32) -> !pto.pipe

    %c2v_import = pto.import_reserved_buffer {
      name = "c2v_fifo",
      peer_func = @vector_kernel
    } -> i32
    %c2v_pipe = pto.initialize_l2g2l_pipe {
      dir_mask = 1,
      slot_size = 1024,
      slot_num = 8,
      local_slot_num = 8
    }(%gm_slot_buffer : memref<2048xf32, #pto.address_space<gm>>, %c2v_import : i32) -> !pto.pipe

    %acc_tile = pto.alloc_tile : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>
    pto.tpush(%acc_tile, %c2v_pipe : !pto.tile_buf<loc=acc, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=col_major, slayout=row_major, fractal=1024, pad=0>, !pto.pipe) {split = 0}

    %recv_tile = pto.declare_tile -> !pto.tile_buf<loc=mat, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=1024, pad=0>
    pto.tpop(%recv_tile, %v2c_pipe : !pto.tile_buf<loc=mat, dtype=f32, rows=16, cols=16, v_row=16, v_col=16, blayout=row_major, slayout=none_box, fractal=1024, pad=0>, !pto.pipe) {split = 1}
    pto.tfree(%v2c_pipe : !pto.pipe) {split = 2}
    return
  }

  func.func @vector_kernel(%gm_slot_buffer: memref<2048xf32, #pto.address_space<gm>>)
      attributes {pto.kernel_kind = #pto.kernel_kind<vector>} {
    %send_tile = pto.alloc_tile : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tadd ins(%send_tile, %send_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>,
        !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
      outs(%send_tile
      : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    %c2v_local = pto.reserve_buffer {
      name = "c2v_fifo",
      size = 8192,
      location = #pto.address_space<vec>,
      auto = true
    } -> i32
    %c2v_pipe = pto.initialize_l2g2l_pipe {
      dir_mask = 1,
      slot_size = 1024,
      slot_num = 8,
      local_slot_num = 8
    }(%gm_slot_buffer : memref<2048xf32, #pto.address_space<gm>>, %c2v_local : i32) -> !pto.pipe

    %v2c_import = pto.import_reserved_buffer {
      name = "v2c_fifo",
      peer_func = @cube_kernel
    } -> i32
    %v2c_pipe = pto.initialize_l2g2l_pipe {
      dir_mask = 2,
      slot_size = 1024,
      slot_num = 8,
      local_slot_num = 8
    }(%gm_slot_buffer : memref<2048xf32, #pto.address_space<gm>>, %v2c_import : i32) -> !pto.pipe

    pto.tpush(%send_tile, %v2c_pipe : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.pipe) {split = 0}

    %fifo_tile = pto.declare_tile -> !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    pto.tpop(%fifo_tile, %c2v_pipe : !pto.tile_buf<loc=vec, dtype=f32, rows=8, cols=16, v_row=8, v_col=16, blayout=row_major, slayout=none_box, fractal=512, pad=0>, !pto.pipe) {split = 1}
    pto.tfree(%c2v_pipe : !pto.pipe) {split = 2}
    return
  }
}

// A3-LABEL: AICORE void cube_kernel(
// A3: int32_t [[CUBE_C2V_ADDR:v[0-9]+]] = 512;
// A3: auto {{v[0-9]+}} = TPipe<2, Direction::DIR_V2C, 1024, 8, 8>(
// A3: auto {{v[0-9]+}} = TPipe<0, Direction::DIR_C2V, 1024, 8, 8>({{v[0-9]+}}, [[CUBE_C2V_ADDR]], {{v[0-9]+}});

// A3-LABEL: AICORE void vector_kernel(
// A3: int32_t [[VEC_C2V_ADDR:v[0-9]+]] = 512;
// A3: auto {{v[0-9]+}} = TPipe<0, Direction::DIR_C2V, 1024, 8, 8>({{v[0-9]+}}, [[VEC_C2V_ADDR]], {{v[0-9]+}});
// A3: auto {{v[0-9]+}} = TPipe<2, Direction::DIR_V2C, 1024, 8, 8>(
