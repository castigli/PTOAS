// RUN: ptoas --pto-level=level3 --pto-arch a5 --enable-insert-sync --emit-pto-ir %s | FileCheck %s --check-prefix=INSERT
// RUN: ptoas --pto-level=level3 --pto-arch a5 --enable-graph-sync-solver --graph-sync-solver-event-id-max=8 --emit-pto-ir %s | FileCheck %s --check-prefix=GSS

module {

  // INSERT-LABEL: func.func @mte2_v_uses_event_id7
  // INSERT: pto.set_flag[<PIPE_MTE2>, <PIPE_V>, <EVENT_ID7>]
  // INSERT: pto.wait_flag[<PIPE_MTE2>, <PIPE_V>, <EVENT_ID7>]
  // GSS-LABEL: func.func @mte2_v_uses_event_id7
  // GSS: pto.set_flag[<PIPE_MTE2>, <PIPE_V>, <EVENT_ID7>]
  // GSS: pto.wait_flag[<PIPE_MTE2>, <PIPE_V>, <EVENT_ID7>]
  func.func @mte2_v_uses_event_id7(%arg0: !pto.ptr<f32>,
                                   %arg1: index, %arg2: index,
                                   %arg3: index, %arg4: index,
                                   %arg5: index) {
    %c0 = arith.constant 0 : index
    %c1 = arith.constant 1 : index
    %c16 = arith.constant 16 : index
    %c1024 = arith.constant 1024 : index
    %c1048576 = arith.constant 1048576 : index
    %addr0 = arith.constant 0 : i64
    %addr1 = arith.constant 16384 : i64
    %addr2 = arith.constant 32768 : i64
    %addr3 = arith.constant 49152 : i64
    %addr4 = arith.constant 65536 : i64
    %addr5 = arith.constant 81920 : i64
    %addr6 = arith.constant 98304 : i64
    %addr7 = arith.constant 114688 : i64
    %one = arith.constant 1.000000e+00 : f32

    %src_view = pto.make_tensor_view %arg0,
            shape = [%c1, %c1, %c16, %c1024, %c1024],
            strides = [%c1048576, %c1048576, %c1048576, %c1024, %c1]
            : !pto.tensor_view<1x1x16x1024x1024xf32>
    %src_part = pto.partition_view %src_view,
            offsets = [%c0, %c0, %c0, %c0, %c0],
            sizes = [%arg1, %arg2, %arg3, %arg4, %arg5]
            : !pto.tensor_view<1x1x16x1024x1024xf32>
              -> !pto.partition_tensor_view<?x?x?x?x?xf32>

    %tmp0 = arith.muli %arg1, %arg2 : index
    %tmp1 = arith.muli %tmp0, %arg3 : index
    %tmp2 = arith.muli %tmp1, %arg4 : index

    %tile0 = pto.alloc_tile addr = %addr0 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile1 = pto.alloc_tile addr = %addr1 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile2 = pto.alloc_tile addr = %addr2 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile3 = pto.alloc_tile addr = %addr3 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile4 = pto.alloc_tile addr = %addr4 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile5 = pto.alloc_tile addr = %addr5 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile6 = pto.alloc_tile addr = %addr6 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>
    %tile7 = pto.alloc_tile addr = %addr7 valid_row = %tmp2 valid_col = %arg5
            : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>

    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile0 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile1 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile2 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile3 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile4 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile5 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile6 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tload ins(%src_part : !pto.partition_tensor_view<?x?x?x?x?xf32>)
            outs(%tile7 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    pto.tmuls ins(%tile0, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile0 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile1, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile1 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile2, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile2 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile3, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile3 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile4, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile4 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile5, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile5 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile6, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile6 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)
    pto.tmuls ins(%tile7, %one : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>, f32)
            outs(%tile7 : !pto.tile_buf<loc=vec, dtype=f32, rows=256, cols=16, v_row=?, v_col=?, blayout=row_major, slayout=none_box, fractal=512, pad=0>)

    return
  }
}
